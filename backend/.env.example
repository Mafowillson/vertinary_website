# PostgreSQL — use the same database in pgAdmin 4
# Create DB first:  CREATE DATABASE vertinary_db;
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/vertinary_db

SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOAD_DIR=uploads
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@your-domain.com
VERIFICATION_URL_BASE=http://localhost:5173/verify-email
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# Local dev without mail: use console (link printed in server logs). Production: smtp + credentials below.
VERIFICATION_EMAIL_MODE=console
